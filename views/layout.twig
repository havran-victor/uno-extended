<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}UNO Extended{% endblock %}</title>
    <style>
        body { font-family: system-ui, sans-serif; max-width: 900px; margin: 2em auto; padding: 0 1em; color: #222; }
        h1, h2 { border-bottom: 1px solid #ddd; padding-bottom: 0.3em; }
        nav a { margin-right: 1em; }
        table { border-collapse: collapse; width: 100%; margin-bottom: 1em; }
        th, td { border: 1px solid #ccc; padding: 0.4em 0.6em; text-align: left; }
        th { background: #f0f0f0; }
        form { margin: 1em 0; padding: 1em; background: #fafafa; border: 1px solid #ddd; }
        input, select, button { padding: 0.4em; margin: 0.2em 0; }
        .badge { display: inline-block; padding: 0.1em 0.5em; border-radius: 3px; font-size: 0.85em; background: #eef; }
        .err { color: #c33; }
        .ok { color: #283; }
    </style>
</head>
<body>
    <nav>
        <a href="{{ basePath }}/games-view">Games</a>
        <a href="{{ basePath }}/leaderboard-view">Leaderboard</a>
        <a href="{{ basePath }}/swagger/">Swagger UI</a>
    </nav>
    {% if flash %}<p class="{{ flash.type }}">{{ flash.message }}</p>{% endif %}
    {% block content %}{% endblock %}
</body>
</html>
